# Database connection (Prisma v7 format for migrations)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your-api-key-here

# Direct PostgreSQL connection (used at runtime by pg adapter)
DATABASE_URL_DIRECT=postgresql://user:password@host:5432/database

# JWT secret for admin authentication (REQUIRED in production)
ADMIN_SECRET=your-secret-here

# Google OAuth for admin sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=  # e.g. https://<domain>/api/auth/google/callback
