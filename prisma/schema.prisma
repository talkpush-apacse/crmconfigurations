generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Checklist {
  id          String   @id @default(cuid())
  slug        String   @unique
  editorToken String   @unique @default(uuid())
  clientName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version       Int      @default(0)
  fieldVersions Json?    @default("{}")

  enabledTabs             Json?
  tabOrder                Json?
  tabFilledBy             Json?
  communicationChannels   Json?
  featureToggles          Json?
  configuratorChecklist   Json?

  companyInfo   Json?
  users         Json?
  campaigns     Json?
  sites         Json?
  prescreening  Json?
  messaging     Json?
  sources       Json?
  folders       Json?
  documents     Json?
  attributes    Json?
  fbWhatsapp    Json?
  instagram     Json?
  aiCallFaqs    Json?
  agencyPortal      Json?
  agencyPortalUsers Json?
  rejectionReasons  Json?
  labels            Json?
  adminSettings     Json?
  atsIntegrations   Json?
  integrations      Json     @default("[]")
  tabUploadMeta     Json?

  autoflows      Json?

  isCustom       Boolean  @default(false)
  customSchema   Json?
  customData     Json?
  customTabs     Json?

  @@index([clientName])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
}
