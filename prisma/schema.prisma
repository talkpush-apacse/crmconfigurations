generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model Checklist {
  id          String   @id @default(cuid())
  slug        String   @unique
  clientName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version       Int      @default(0)
  fieldVersions Json?    @default("{}")

  enabledTabs             Json?
  communicationChannels   Json?
  featureToggles          Json?

  companyInfo   Json?
  users         Json?
  campaigns     Json?
  sites         Json?
  prescreening  Json?
  messaging     Json?
  sources       Json?
  folders       Json?
  documents     Json?
  fbWhatsapp    Json?
  instagram     Json?
  aiCallFaqs    Json?
  agencyPortal    Json?
  adminSettings   Json?

  assignments ChecklistAssignment[]

  @@index([clientName])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())

  assignments ChecklistAssignment[]
}

model ChecklistAssignment {
  id          String    @id @default(cuid())
  userId      String
  checklistId String
  createdAt   DateTime  @default(now())

  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@unique([userId, checklistId])
  @@index([userId])
  @@index([checklistId])
}
