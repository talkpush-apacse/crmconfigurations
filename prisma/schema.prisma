generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Checklist {
  id          String   @id @default(cuid())
  slug        String   @unique
  editorToken String   @unique @default(uuid())
  clientName  String
  ownerEmail  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version       Int      @default(0)
  fieldVersions Json?    @default("{}")
  notificationState Json?

  enabledTabs             Json?
  tabOrder                Json?
  tabFilledBy             Json?
  communicationChannels   Json?
  featureToggles          Json?
  configuratorChecklist   Json?

  companyInfo   Json?
  users         Json?
  campaigns     Json?
  sites         Json?
  prescreening  Json?
  messaging     Json?
  sources       Json?
  folders       Json?
  documents     Json?
  attributes    Json?
  fbWhatsapp    Json?
  instagram     Json?
  aiCallFaqs    Json?
  agencyPortal      Json?
  agencyPortalUsers Json?
  rejectionReasons  Json?
  labels            Json?
  adminSettings     Json?
  atsIntegrations   Json?
  integrations      Json     @default("[]")
  tabUploadMeta     Json?

  autoflows      Json?

  isCustom       Boolean  @default(false)
  customSchema   Json?
  customData     Json?
  customTabs     Json?

  snapshots      ChecklistSnapshot[]

  @@index([clientName])
}

model ChecklistSnapshot {
  id                String    @id @default(cuid())
  checklistId       String
  checklist         Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  label             String?
  description       String?
  isLabeled         Boolean   @default(false)

  payload           Json
  versionAtSnapshot Int

  createdAt         DateTime  @default(now())
  createdBy         String
  createdByLabel    String?

  archived          Boolean   @default(false)
  archivedAt        DateTime?

  @@index([checklistId, createdAt])
  @@index([checklistId, archived])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
}
